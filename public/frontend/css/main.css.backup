  margin-right: 15px;
  /*font-size: 20px;*/
  font-size: 18px;
  color: rgba(255, 255, 255, 0.4);
  background-color: transparent;
  width: -moz-fit-content;
  width: fit-content;
  padding-bottom: 10px;
